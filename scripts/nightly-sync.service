[Unit]
Description=Claude Code nightly project sync loop
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
User=ec2-user
Environment=HOME=/home/ec2-user
Environment=PATH=/home/ec2-user/.local/bin:/home/ec2-user/.nvm/versions/node/current/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=/home/ec2-user
ExecStart=/bin/bash /home/ec2-user/llm-skills/scripts/start-nightly-sync.sh
ExecStop=/usr/bin/screen -S nightly-sync -X quit
RemainAfterExit=yes
Restart=on-failure
RestartSec=300

[Install]
WantedBy=multi-user.target
